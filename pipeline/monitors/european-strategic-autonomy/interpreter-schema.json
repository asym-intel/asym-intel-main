        "cycle_disposition": {
          "type": "string",
          "enum": [
            "material_change",
            "null_cycle",
            "partial_cycle",
            "error_cycle"
          ],
          "description": "Interpreter's judgment on the cycle. 'material_change' = at least one module has new content; 'null_cycle' = evidence bundle carries no material change; 'partial_cycle' = mixed; 'error_cycle' = reserved for engine-level failure paths (engine stamps, prompt does not emit)."
        },
        "cycle_disposition_reason": {
          "type": ["string", "null"],
          "description": "One-sentence justification. Required for null_cycle and partial_cycle; optional otherwise."
        },
        "triple_extraction_manifest": {
          "type": "object",
          "description": "Provenance of structured_claims[] extraction.",
          "properties": {
            "deterministic_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_model": {
              "type": ["string", "null"]
            },
            "llm_fallback_temperature": {
              "type": ["number", "null"]
            },
            "llm_fallback_timestamp": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": false
        },
        "replay_mode": {
          "type": "boolean",
          "description": "Engine-stamped true when WEEKLY_FILE_OVERRIDE was active on the dispatch. Absent/false in production dispatches."
        },
        "replay_window": {
          "type": "object",
          "description": "Required iff replay_mode is true. Holds the replay cycle window.",
          "properties": {
            "start": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD)."
            },
            "end": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD)."
            }
          },
          "required": ["start", "end"]
        }
      }
    },
