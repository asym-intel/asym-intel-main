        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "judgment": {"type": "string"},
          "confidence_preliminary": {
            "type": "string",
            "enum": ["High", "Assessed", "Possible"]
          },
          "domain_affected": {"type": "string"},
          "trajectory": {
            "type": "string",
            "enum": ["Improving", "Stable", "Worsening"]
          },
          "source_urls": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "cross_monitor_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_monitor": {"type": "string"},
          "signal": {"type": "string"},
          "type": {"type": "string"},
          "confidence_preliminary": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          }
        }
      }
    },
    "structured_claims": {
      "type": "array",
      "description": "Triple store of every factual assertion in this interpretation.",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "entity",
          "predicate",
          "value",
          "evidence_id",
          "confidence",
          "source_module"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^esa-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}$",
            "description": "Stable within a cycle. Format: esa-int-{ISO-date}-{4-digit-sequence}."
          },
          "entity": {
            "type": "string",
            "minLength": 1
          },
          "predicate": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"},
              {"type": "object"},
              {"type": "array"}
            ],
            "description": "The asserted value. Accept string/number/object/array."
          },
          "evidence_id": {
            "type": "string",
            "minLength": 1,
            "description": "References weekly-research source_id or KB entry_id."
          },
          "confidence": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          },
          "source_module": {
            "type": "string",
            "description": "Which module or field the claim first appears in."
          },
          "notes": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "gaps_register": {
      "type": "array",
      "description": "Optional. What evidence would improve Uncertain claims.",
      "items": {
        "type": "object",
        "required": ["gap_id", "description"],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^esa-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-G[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "affected_claims": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "proposed_patches": {
      "type": "array",
      "description": "OPTIONAL top-level array naming material-change patches per pipeline-doctrine Appendix A. Under null_cycle the prompt contract requires an empty array (never omission).",
      "items": {
        "type": "object",
        "required": [
          "rule_applied",
          "evidence_ids",
          "confidence",
          "material_change_justification",
          "target_kb_path"
        ],
        "properties": {
          "rule_applied": {"type": "string", "minLength": 1},
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "confidence": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          },
          "material_change_justification": {"type": "string", "minLength": 1},
          "target_kb_path": {"type": "string", "minLength": 1},
          "patch_id": {"type": "string"},
          "operation": {
            "type": "string",
            "enum": ["create", "update", "archive", "carry-forward-verified"]
          },
          "prior_value": {},
          "new_value": {},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    }
,
  "eu_legislation_tracker": {
