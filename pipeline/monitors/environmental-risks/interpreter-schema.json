{
  "$comment": "sprint-bw: added tipping_system_flags, regional_cascade_chains, open_findings",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ERM Interpreter Output Schema (erm-interpret-v1.0)",
  "description": "Output schema for the ERM Interpreter stage. Sprint C.E Phase 1 structural parity to AGM (AD-2026-04-24n). Consumed by ERM Composer (weekly_brief_draft + claim_trace) and ERM Reviewer gate.",
  "type": "object",
  "required": [
    "_meta",
    "lead_signal",
    "planetary_status_snapshot",
    "planetary_boundary_tracker",
    "tipping_point_tracker",
    "extreme_events_log",
    "climate_security_nexus",
    "policy_law_compliance",
    "icj_tracker",
    "loss_damage_tracker",
    "attribution_gap_cases",
    "reverse_cascade_check",
    "regional_coverage",
    "key_judgments",
    "delta_strip",
    "jurisdiction_risk_matrix",
    "environmental_governance_composite",
    "cross_monitor_candidates",
    "structured_claims",
    "tipping_system_flags",
    "regional_cascade_chains",
    "open_findings"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schema_version", "monitor_slug", "synthesised_at", "week_ending"],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": ["erm-interpret-v1.0"],
          "description": "Must be exactly 'erm-interpret-v1.0'."
        },
        "monitor_slug": {
          "type": "string",
          "const": "environmental-risks"
        },
        "synthesised_at": {
          "type": "string"
        },
        "week_ending": {
          "type": "string"
        },
        "null_signal_week": {
          "type": "boolean"
        },
        "null_signal_reason": {
          "type": ["string", "null"]
        },
        "cycle_disposition": {
          "type": "string",
          "enum": ["material_change", "null_cycle", "partial_cycle", "error_cycle"],
          "description": "Interpreter judgment on the cycle. error_cycle is reserved for engine-level failure paths."
        },
        "cycle_disposition_reason": {
          "type": ["string", "null"],
          "description": "One-sentence justification. Required for null_cycle and partial_cycle."
        },
        "triple_extraction_manifest": {
          "type": "object",
          "properties": {
            "deterministic_extractions": {"type": "integer", "minimum": 0},
            "llm_fallback_extractions": {"type": "integer", "minimum": 0},
            "llm_fallback_model": {"type": ["string", "null"]},
            "llm_fallback_temperature": {"type": ["number", "null"]},
            "llm_fallback_timestamp": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        "replay_mode": {
          "type": "boolean",
          "description": "Engine-stamped true when WEEKLY_FILE_OVERRIDE was active. Not model-derived."
        },
        "replay_window": {
          "type": ["object", "null"],
          "description": "Required iff replay_mode is true.",
          "properties": {
            "start": {"type": "string"},
            "end": {"type": "string"}
          },
          "required": ["start", "end"]
        }
      }
    },
    "lead_signal": {
      "type": "object",
      "required": ["headline", "body", "source_url", "confidence_preliminary"],
      "properties": {
        "headline": {"type": "string"},
        "body": {"type": "string"},
        "source_url": {"type": "string"},
        "confidence_preliminary": {
          "type": "string",
          "enum": ["Confirmed", "High", "Assessed", "Possible"]
        }
      }
    },
    "planetary_status_snapshot": {
      "type": "object",
      "properties": {
        "boundaries_exceeded": {"type": "integer", "minimum": 0},
        "boundaries_high_risk": {"type": "integer", "minimum": 0},
        "boundaries_increasing_risk": {"type": "integer", "minimum": 0},
        "boundaries_safe": {"type": "integer", "minimum": 0},
        "status_delta_this_week": {"type": "string", "enum": ["Stable", "Worsening", "Improving"]},
        "lead_signal": {"type": "string"}
      }
    },
    "planetary_boundary_tracker": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "boundary": {"type": "string"},
          "status": {"type": "string", "enum": ["Safe", "Increasing risk", "Transgressed", "Beyond high risk"]},
          "status_delta": {"type": "string", "enum": ["Stable", "Worsening", "Improving"]},
          "key_indicator": {"type": "string"},
          "data_source": {"type": "string"},
          "week_development": {"type": ["string", "null"]},
          "filter_tags": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "asymmetric": {"type": "string"}
        }
      }
    },
    "tipping_point_tracker": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tipping_element": {"type": "string"},
          "context_system_name": {"type": ["string", "null"]},
          "proximity": {"type": "string", "enum": ["Distant", "Approaching", "Imminent", "Crossed"]},
          "probability_preliminary": {"type": "string", "enum": ["Low", "Medium", "High", "Critical"]},
          "key_indicator": {"type": "string"},
          "cascade_risk": {"type": ["string", "null"]},
          "cascade_chain": {"type": ["string", "null"]},
          "source": {"type": "string"},
          "amoc_fovs_proxy": {"type": ["string", "null"]},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "asymmetric": {"type": "string"}
        }
      }
    },
    "extreme_events_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_type": {"type": "string"},
          "location": {"type": "string"},
          "severity": {"type": "string", "enum": ["Moderate", "Severe", "Extreme", "Record-breaking"]},
          "non_linear_departure": {"type": "boolean"},
          "non_linear_test_result": {"type": ["string", "null"]},
          "geopolitical_implication": {"type": ["string", "null"]},
          "conflict_nexus": {"type": "boolean"},
          "conflict_nexus_note": {"type": ["string", "null"]},
          "filter_tags": {"type": "array", "items": {"type": "string"}},
          "source_url": {"type": "string"},
          "asymmetric": {"type": "string"}
        }
      }
    },
    "climate_security_nexus": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk_type": {"type": "string"},
          "region": {"type": "string"},
          "severity": {"type": "string", "enum": ["Emerging", "Moderate", "Severe", "Critical"]},
          "conflict_link": {"type": ["string", "null"]},
          "scem_link": {"type": ["string", "null"]},
          "cascade_chain": {"type": "string"},
          "asymmetric": {"type": "string"},
          "source_url": {"type": "string"}
        }
      }
    },
    "policy_law_compliance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {"type": "string"},
          "jurisdiction": {"type": "string"},
          "type": {"type": "string"},
          "status": {"type": "string"},
          "filter_tag": {"type": "string"},
          "governance_gap": {"type": ["string", "null"]},
          "root_cause": {"type": ["string", "null"]},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "source": {"type": "string"},
          "asymmetric": {"type": "string"}
        }
      }
    },
    "icj_tracker": {
      "type": "object",
      "required": ["status", "last_development", "significance", "source_url"],
      "properties": {
        "status": {"type": "string"},
        "last_development": {"type": "string"},
        "last_development_date": {"type": ["string", "null"]},
        "next_milestone": {"type": ["string", "null"]},
        "significance": {"type": "string"},
        "source_url": {"type": "string"}
      }
    },
    "loss_damage_tracker": {
      "type": "object",
      "required": ["mechanism_status", "key_development"],
      "properties": {
        "mechanism_status": {"type": "string", "enum": ["Operationalised", "Disbursing", "Stalled", "Under review"]},
        "committed_usd": {"type": "number"},
        "disbursed_usd": {"type": "number"},
        "disbursement_ratio": {"type": "number"},
        "compliance_cycle": {"type": "string"},
        "key_development": {"type": "string"},
        "filter_tag": {"type": "string"},
        "source": {"type": "string"}
      }
    },
    "attribution_gap_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "case": {"type": "string"},
          "governance_status": {"type": "string"},
          "this_week_development": {"type": ["string", "null"]},
          "filter_tag": {"type": "string"},
          "key_metric": {"type": ["string", "null"]},
          "source": {"type": ["string", "null"]}
        }
      }
    },
    "reverse_cascade_check": {
      "type": "object",
      "required": ["checked", "note"],
      "properties": {
        "checked": {"type": "boolean"},
        "geopolitical_event": {"type": ["string", "null"]},
        "accelerates_boundary": {"type": "boolean"},
        "affected_boundary": {"type": ["string", "null"]},
        "cascade_description": {"type": ["string", "null"]},
        "note": {"type": "string"}
      }
    },
    "weaponisation_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_summary": {"type": "string"},
          "actor": {"type": "string"},
          "target": {"type": "string"},
          "natural_asset": {"type": "string"},
          "earth_system_impact": {"type": "string"},
          "filter_classification": {
            "type": "object",
            "properties": {
              "f1_threat_multiplier": {"type": "boolean"},
              "f2_regulatory_vacuum": {"type": "boolean"},
              "f3_tipping_point_precursor": {"type": "boolean"},
              "f4_attribution_gap": {"type": "boolean"}
            }
          },
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "source": {"type": "string"}
        }
      }
    },
    "aerosol_dual_risk_flag": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "region": {"type": "string"},
          "cooling_masking_estimate_w_m2": {"type": "number"},
          "pm25_mortality_indicator": {"type": ["string", "null"]},
          "dual_risk_summary": {"type": "string"},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "source": {"type": "string"}
        }
      }
    },
    "regional_coverage": {
      "type": "object",
      "properties": {
        "sub_saharan_africa_items": {"type": "integer", "minimum": 0},
        "mena_items": {"type": "integer", "minimum": 0},
        "south_asia_items": {"type": "integer", "minimum": 0},
        "ocean_systems_items": {"type": "integer", "minimum": 0},
        "fm_erm_02_met": {"type": "boolean"},
        "note": {"type": "string"}
      }
    },
    "jurisdiction_risk_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "jurisdiction": {"type": "string"},
          "environmental_framework_readiness": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
          "enforcement_capacity": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
          "climate_exposure": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
          "overall_risk": {"type": "string", "enum": ["HIGH", "ELEVATED", "MODERATE", "LOW"]},
          "key_development": {"type": "string"},
          "trajectory": {"type": "string", "enum": ["Improving", "Stable", "Deteriorating"]}
        }
      }
    },
    "environmental_governance_composite": {
      "type": "object",
      "properties": {
        "score": {"type": "number"},
        "direction": {"type": "string", "enum": ["Improving", "Stable", "Deteriorating"]},
        "components": {
          "type": "object",
          "properties": {
            "regulatory_coverage": {"type": "string"},
            "enforcement_capacity": {"type": "string"},
            "scientific_readiness": {"type": "string"},
            "mitigation_alignment": {"type": "string"},
            "international_coordination": {"type": "string"}
          }
        },
        "note": {"type": "string"}
      }
    },
    "key_judgments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "judgment": {"type": "string"},
          "confidence_preliminary": {"type": "string", "enum": ["High", "Assessed", "Possible"]},
          "boundary_or_element": {"type": "string"},
          "trajectory": {"type": "string", "enum": ["Improving", "Stable", "Worsening"]},
          "source_urls": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "delta_strip": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rank": {"type": "integer"},
          "title": {"type": "string"},
          "label": {"type": "string"},
          "delta_type": {"type": "string", "enum": ["New", "Escalation", "De-escalation", "Status Change", "Threshold"]},
          "one_line": {"type": "string"}
        }
      }
    },
    "cross_monitor_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_monitor": {"type": "string"},
          "signal": {"type": "string"},
          "type": {"type": "string"},
          "confidence_preliminary": {"type": "string", "enum": ["High", "Assessed", "Possible"]}
        }
      }
    },
    "structured_claims": {
      "type": "array",
      "description": "Triple store of every factual assertion in this interpretation. Populated by the Interpreter; consumed by the Composer (claim_trace provenance) and the Reviewer gate.",
      "items": {
        "type": "object",
        "required": ["claim_id", "entity", "predicate", "value", "evidence_id", "confidence", "source_module"],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^erm-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}$",
            "description": "Format: erm-int-{ISO-date}-{4-digit-sequence}. Reset per cycle."
          },
          "entity": {"type": "string", "minLength": 1},
          "predicate": {"type": "string", "minLength": 1},
          "value": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"},
              {"type": "object"},
              {"type": "array"}
            ]
          },
          "evidence_id": {"type": "string", "minLength": 1},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "source_module": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "gaps_register": {
      "type": "array",
      "description": "Optional. What evidence would improve Uncertain claims.",
      "items": {
        "type": "object",
        "required": ["gap_id", "description"],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^erm-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-G[0-9]{3}$"
          },
          "description": {"type": "string", "minLength": 1},
          "affected_claims": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "proposed_patches": {
      "type": "array",
      "description": "Optional. Material-change patches for the Applier per pipeline-doctrine Appendix A. Empty array under null_cycle.",
      "items": {
        "type": "object",
        "required": ["rule_applied", "evidence_ids", "confidence", "material_change_justification", "target_kb_path"],
        "properties": {
          "rule_applied": {"type": "string", "minLength": 1},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "confidence": {"type": "string", "enum": ["Confirmed", "High", "Assessed", "Possible"]},
          "material_change_justification": {"type": "string", "minLength": 1},
          "target_kb_path": {"type": "string", "minLength": 1},
          "patch_id": {"type": "string"},
          "operation": {"type": "string", "enum": ["create", "update", "archive", "carry-forward-verified"]},
          "prior_value": {},
          "new_value": {},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "weaponisation_events": {
      "type": "array"
    },
    "aerosol_dual_risk_flag": {
      "type": "array"
    },
  "tipping_system_flags": {
    "type": "array",
    "description": "Earth-system tipping point assessments with status and proxy metrics.",
    "items": {
      "type": "object",
      "required": ["system", "status", "proxy_metric", "proxy_value", "collapse_probability_range"],
      "properties": {
        "system":                     { "type": "string" },
        "status":                     {
          "type": "string",
          "enum": ["Critical", "High", "Elevated", "Moderate"]
        },
        "proxy_metric":               { "type": "string" },
        "proxy_value":                { "type": "string" },
        "collapse_probability_range": { "type": "string" }
      }
    }
  },
  "regional_cascade_chains": {
    "type": "array",
    "description": "Physical to human to political cascade chains by region.",
    "items": {
      "type": "object",
      "required": ["region", "chain", "status", "current_stage", "reverse_cascade"],
      "properties": {
        "region":          { "type": "string" },
        "chain":           { "type": "string" },
        "status":          { "type": "string", "enum": ["Active", "Monitoring"] },
        "current_stage":   { "type": "string" },
        "reverse_cascade": { "type": "string" }
      }
    }
  },
  "open_findings": {
    "type": "array",
    "description": "Salient environmental findings from the weekly research bundle not captured in other structured fields.",
    "items": {
      "type": "object",
      "required": ["headline", "why_it_matters", "source_url", "source_name", "source_tier"],
      "properties": {
        "headline":       { "type": "string" },
        "why_it_matters": { "type": "string" },
        "source_url":     { "type": "string", "format": "uri" },
        "source_name":    { "type": "string" },
        "source_tier":    { "type": "string", "enum": ["T1", "T2", "T3"] }
      }
    }
  }
  }
}
