{
  "$comment": "sprint-bw: added conviction_history, blind_spots, active_tactical_alerts, open_findings",
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "gmm-interpret-v1.0"
          ],
          "description": "Must be exactly 'gmm-interpret-v1.0'."
        },
        "monitor_slug": {
          "type": "string",
          "const": "macro-monitor"
        },
        "synthesised_at": {
          "type": "string"
        },
        "week_ending": {
          "type": "string"
        },
        "null_signal_week": {
          "type": "boolean"
        },
        "null_signal_reason": {
          "type": ["string", "null"]
        },
        "cycle_disposition": {
          "type": "string",
          "enum": [
            "material_change",
            "null_cycle",
            "partial_cycle",
            "error_cycle"
          ],
          "description": "Interpreter's judgment on the cycle. 'material_change' = at least one module has new content; 'null_cycle' = evidence bundle carries no material change; 'partial_cycle' = mixed; 'error_cycle' = reserved for engine-level failure paths (engine stamps, prompt does not emit)."
        },
        "cycle_disposition_reason": {
          "type": ["string", "null"],
          "description": "One-sentence justification. Required for null_cycle and partial_cycle; optional otherwise."
        },
        "triple_extraction_manifest": {
          "type": "object",
          "description": "Provenance of structured_claims[] extraction.",
          "properties": {
            "deterministic_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_timestamp": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": false
        },
        "replay_mode": {
          "type": "boolean",
          "description": "Engine-stamped true when WEEKLY_FILE_OVERRIDE was active on the dispatch. Absent or false in production dispatches. Not model-derived; the Interpreter does not emit this field."
        },
        "replay_window": {
          "type": "object",
          "description": "Required iff replay_mode is true. Holds the replay cycle window. Not model-derived.",
          "properties": {
            "start": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD). week_ending - 6 days."
            },
            "end": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD). Copied from the override bundle's _meta.week_ending."
            }
          },
          "required": ["start", "end"]
        }
      }
    },
    "lead_signal": {
      "type": "object",
      "required": [
        "headline",
        "domain",
        "body",
        "source_url",
        "confidence_preliminary"
