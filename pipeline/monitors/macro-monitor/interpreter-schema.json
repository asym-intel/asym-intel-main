    "structured_claims": {
      "type": "array",
      "description": "Triple store of every factual assertion in this interpretation. Populated by the Interpreter; consumed by the Composer (for claim_trace[] provenance) and the Reviewer gate.",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "entity",
          "predicate",
          "value",
          "evidence_id",
          "confidence",
          "source_module"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^gmm-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}$",
            "description": "Stable within a cycle. Format: gmm-int-{ISO-date}-{4-digit-sequence}."
          },
          "entity": {
            "type": "string",
            "minLength": 1
          },
          "predicate": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"},
              {"type": "object"},
              {"type": "array"}
            ],
            "description": "The asserted value. Accept string/number/object/array."
          },
          "evidence_id": {
            "type": "string",
            "minLength": 1,
            "description": "References weekly-research source_id or KB entry_id."
          },
          "confidence": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          },
          "source_module": {
            "type": "string",
            "description": "Which module or field the claim first appears in."
          },
          "notes": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "gaps_register": {
      "type": "array",
      "description": "Optional. What evidence would improve Uncertain claims.",
      "items": {
        "type": "object",
        "required": [
          "gap_id",
          "description"
        ],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^gmm-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-G[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "affected_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "proposed_patches": {
      "type": "array",
      "description": "OPTIONAL. Material-change patches proposed to the Applier. Under null_cycle the prompt contract requires an empty array (never omission). Each patch carries the 5 Appendix A required fields.",
      "items": {
        "type": "object",
        "required": [
          "rule_applied",
          "evidence_ids",
          "confidence",
          "material_change_justification",
          "target_kb_path"
        ],
        "properties": {
          "rule_applied": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          },
          "material_change_justification": {
            "type": "string",
            "minLength": 1
          },
          "target_kb_path": {
            "type": "string",
            "minLength": 1
          },
          "patch_id": {
            "type": "string"
          },
          "operation": {
            "type": "string",
            "enum": ["create", "update", "archive", "carry-forward-verified"]
          },
          "prior_value": {},
          "new_value": {},
          "notes": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": true
      }
    }
,
  "conviction_history": {
    "type": "array",
    "description": "Chronological weekly conviction assessments — append only.",
    "items": {
      "type": "object",
      "required": ["date", "system_average", "conviction", "regime", "regime_conviction", "rationale"],
      "properties": {
        "date":              { "type": "string", "format": "date" },
        "system_average":    { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "conviction":        { "type": "string", "enum": ["MEDIUM", "HIGH"] },
        "regime":            { "type": "string" },
        "regime_conviction": { "type": "string", "enum": ["MEDIUM", "HIGH"] },
        "rationale":         { "type": "string" }
      }
    }
  },
  "blind_spots": {
    "type": "array",
    "description": "Identified structural gaps in data coverage or analytical scope.",
    "items": {
      "type": "object",
      "required": ["id", "name", "description", "evidence_id", "source_url"],
      "properties": {
        "id":          { "type": "string" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "evidence_id": { "type": "string" },
        "source_url":  { "type": "string" }
      }
    }
  },
  "active_tactical_alerts": {
    "type": "array",
    "description": "Named tactical alert conditions with traffic-light state.",
    "items": {
      "type": "object",
      "required": ["alert_id", "name", "current_state", "last_state_change", "description"],
      "properties": {
        "alert_id":          { "type": "string" },
        "name":              { "type": "string" },
        "current_state":     { "type": "string", "enum": ["WARNING", "WATCH", "CLEAR"] },
        "last_state_change": { "type": "string", "format": "date" },
        "description":       { "type": "string" }
      }
    }
  },
  "open_findings": {
    "type": "array",
    "description": "Salient macro findings from the weekly research bundle not captured in other structured fields.",
    "items": {
      "type": "object",
      "required": ["headline", "why_it_matters", "source_url", "source_name", "source_tier"],
      "properties": {
        "headline":       { "type": "string" },
        "why_it_matters": { "type": "string" },
        "source_url":     { "type": "string", "format": "uri" },
        "source_name":    { "type": "string" },
        "source_tier":    { "type": "string", "enum": ["T1", "T2", "T3"] }
      }
    }
  }
  },
