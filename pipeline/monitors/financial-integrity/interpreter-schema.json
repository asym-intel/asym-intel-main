{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FIM Interpreter Output Schema (fim-interpret-v1.0)",
  "description": "Output schema for the FIM Interpreter stage. Adapted from WDM interpreter-schema.json (AD-2026-05-01-BQ). Consumed by fim-reviewer.yml (rule engine) and fim-composer.yml.",
  "type": "object",
  "required": ["_meta", "domain_tracker", "structured_claims", "gaps_register"],
  "additionalProperties": true,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schema_version", "monitor_slug", "cycle_disposition"],
      "additionalProperties": true,
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": ["fim-interpret-v1.0"],
          "description": "Must be exactly 'fim-interpret-v1.0'."
        },
        "monitor_slug": {
          "type": "string",
          "const": "financial-integrity"
        },
        "synthesised_at": {
          "type": ["string", "null"]
        },
        "week_ending": {
          "type": ["string", "null"]
        },
        "null_signal_week": {
          "type": "boolean"
        },
        "null_signal_reason": {
          "type": ["string", "null"]
        },
        "cycle_disposition": {
          "type": "string",
          "enum": ["material_change", "null_cycle", "partial_cycle", "error_cycle"],
          "description": "Interpreter judgment on the cycle character."
        },
        "cycle_disposition_reason": {
          "type": ["string", "null"],
          "description": "One-sentence justification. Required for null_cycle and partial_cycle."
        },
        "triple_extraction_manifest": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "deterministic_extractions": {"type": "integer", "minimum": 0},
            "llm_fallback_extractions": {"type": "integer", "minimum": 0},
            "llm_fallback_model": {"type": ["string", "null"]},
            "llm_fallback_timestamp": {"type": ["string", "null"]}
          }
        },
        "replay_mode": {
          "type": "boolean"
        }
      }
    },
    "domain_tracker": {
      "type": "array",
      "description": "D1-D5 domain assessments.",
      "items": {
        "type": "object",
        "required": ["domain", "domain_name"],
        "additionalProperties": true,
        "properties": {
          "domain": {
            "type": "string",
            "enum": ["D1", "D2", "D3", "D4", "D5"]
          },
          "domain_name": {
            "type": "string"
          },
          "trajectory": {
            "type": ["string", "null"]
          },
          "architecture_vs_incident": {
            "type": ["string", "null"],
            "enum": ["architecture", "incident", "mixed", null]
          },
          "key_development": {
            "type": ["string", "null"]
          },
          "confidence": {
            "type": ["string", "null"],
            "enum": ["Confirmed", "High", "Assessed", "Possible", null]
          },
          "developments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["title", "jurisdiction", "summary"],
              "properties": {
                "title": {"type": "string"},
                "jurisdiction": {"type": "string"},
                "pillar": {
                  "type": "string",
                  "enum": ["AML", "CTF", "CPF", "cross-pillar"]
                },
                "actor_category": {"type": ["string", "null"]},
                "severity_preliminary": {"type": ["string", "null"]},
                "architecture_vs_incident": {"type": ["string", "null"]},
                "summary": {"type": "string"},
                "source_name": {"type": ["string", "null"]},
                "source_url": {"type": ["string", "null"]},
                "source_tier": {"type": ["string", "null"]},
                "confidence": {
                  "type": ["string", "null"],
                  "enum": ["Confirmed", "High", "Assessed", "Possible", null]
                },
                "filters_applied": {
                  "type": ["array", "null"],
                  "items": {"type": "string", "enum": ["F1", "F2", "F3", "F4"]}
                }
              }
            }
          }
        }
      }
    },
    "jurisdiction_risk_tracker": {
      "type": "array",
      "description": "Per-jurisdiction risk direction and enforcement/enablement balance.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["jurisdiction"],
        "properties": {
          "jurisdiction": {"type": "string"},
          "risk_direction": {
            "type": "string",
            "enum": ["improving", "deteriorating", "stable", "uncertain"]
          },
          "primary_domains": {
            "type": "array",
            "items": {"type": "string"}
          },
          "enforcement_vs_enablement": {
            "type": "string",
            "enum": ["enforcement", "enablement", "mixed", "capacity_deficit"]
          },
          "structural_vs_episodic": {
            "type": "string",
            "enum": ["structural", "episodic", "mixed"]
          },
          "key_signal": {"type": ["string", "null"]},
          "confidence": {
            "type": ["string", "null"],
            "enum": ["Confirmed", "High", "Assessed", "Possible", null]
          }
        }
      }
    },
    "standing_trackers": {
      "type": "array",
      "description": "T1-T5 standing tracker updates.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["tracker_id", "tracker_name"],
        "properties": {
          "tracker_id": {
            "type": "string",
            "enum": ["T1", "T2", "T3", "T4", "T5"]
          },
          "tracker_name": {"type": "string"},
          "trajectory": {"type": ["string", "null"]},
          "key_development": {"type": ["string", "null"]},
          "confidence": {
            "type": ["string", "null"],
            "enum": ["Confirmed", "High", "Assessed", "Possible", null]
          }
        }
      }
    },
    "structured_claims": {
      "type": "array",
      "description": "Triple store of every factual assertion. Min 5 on material_change cycles.",
      "items": {
        "type": "object",
        "required": ["claim_id", "entity", "predicate", "value", "evidence_id", "confidence", "source_module", "notes", "domain"],
        "additionalProperties": true,
        "properties": {
          "claim_id": {
            "type": "string",
            "description": "Format: fim-YYYY-WNN-NNN"
          },
          "entity": {"type": "string"},
          "predicate": {"type": "string"},
          "value": {"type": "string"},
          "evidence_id": {
            "type": "string",
            "description": "Source identifier — url, source_name, or document reference. Must be non-empty on material_change cycles."
          },
          "confidence": {
            "type": "string",
            "enum": ["Confirmed", "High", "Assessed", "Possible"]
          },
          "source_module": {
            "type": "string",
            "description": "Lineage pointer for applier/source-resolution and reviewer R3. Use weekly_research, reasoner.<section>, persistent.<module>, or daily.<module>."
          },
          "notes": {
            "type": "string",
            "description": "Short provenance or interpretation note explaining why the assertion matters."
          },
          "domain": {
            "type": "string",
            "enum": ["D1", "D2", "D3", "D4", "D5"]
          },
          "pillar": {
            "type": "string",
            "enum": ["AML", "CTF", "CPF", "cross-pillar"]
          },
          "filters_applied": {
            "type": "array",
            "items": {"type": "string", "enum": ["F1", "F2", "F3", "F4"]}
          }
        }
      }
    },
    "key_judgments": {
      "type": "array",
      "description": "Top-line analytical judgments. Three confidence tiers only: High | Assessed | Possible.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["judgment", "confidence"],
        "properties": {
          "judgment": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["High", "Assessed", "Possible"]
          },
          "domain": {"type": ["string", "null"]},
          "supporting_claim_ids": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "cross_monitor_flags": {
      "type": "array",
      "description": "Signals that should be routed to adjacent monitors.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["target_monitor", "signal"],
        "properties": {
          "target_monitor": {
            "type": "string",
            "enum": ["WDM", "GMM", "ESA", "FCW", "AIM", "ERM", "SCEM"]
          },
          "signal": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["Low", "Medium", "High"]
          }
        }
      }
    },
    "gaps_register": {
      "type": "array",
      "description": "Evidence gaps. Non-empty required on null_cycle and whenever uncertain claims exist. Canonical fleet shape per BR-10 F.0a: items require gap_id + description; gap_description retained as legacy alias for backwards-compat (both must be non-empty strings; CI prefers description).",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["gap_id", "description", "gap_description"],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^fim-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-G[0-9]{3}$"
          },
          "description": {"type": "string", "minLength": 1},
          "gap_description": {"type": "string", "minLength": 1, "description": "Legacy alias for description (BR-10 F.0a backwards-compat per verdict E1). New baselines populate both with the same value; future PR removes this field once existing baselines migrate."},
          "affected_claims": {"type": "array", "items": {"type": "string"}},
          "domain": {"type": ["string", "null"]},
          "related_claim_id": {"type": ["string", "null"]}
        }
      }
    }
  }
}
