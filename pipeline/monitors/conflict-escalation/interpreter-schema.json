          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "confidence_preliminary": {
          "type": "string",
          "enum": [
            "Confirmed",
            "High",
            "Assessed",
            "Possible"
          ]
        }
      }
    },
