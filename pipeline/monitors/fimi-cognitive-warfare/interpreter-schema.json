{
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "fcw-interpret-v1.0"
          ],
          "description": "Must be exactly 'fcw-interpret-v1.0'."
        },
        "monitor_slug": {
          "type": "string",
          "const": "fimi-cognitive-warfare"
        },
        "synthesised_at": {
          "type": "string"
        },
        "week_ending": {
          "type": "string"
        },
        "null_signal_week": {
          "type": "boolean"
        },
        "null_signal_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "cycle_disposition": {
          "type": "string",
          "enum": [
            "material_change",
            "null_cycle",
            "partial_cycle",
            "error_cycle"
          ],
          "description": "Interpreter judgment on the cycle. 'material_change' = at least one module has new content; 'null_cycle' = evidence bundle carries no material change; 'partial_cycle' = mixed; 'error_cycle' = reserved for engine-level failure paths."
        },
        "cycle_disposition_reason": {
          "type": [
            "string",
            "null"
          ],
          "description": "One-sentence justification. Required for null_cycle and partial_cycle; optional otherwise."
        },
        "triple_extraction_manifest": {
          "type": "object",
          "description": "Provenance of structured_claims[] extraction.",
          "properties": {
            "deterministic_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_extractions": {
              "type": "integer",
              "minimum": 0
            },
            "llm_fallback_temperature": {
              "type": [
                "number",
                "null"
              ]
            },
            "llm_fallback_timestamp": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "replay_mode": {
          "type": "boolean",
          "description": "Engine-stamped true when WEEKLY_FILE_OVERRIDE was active on the dispatch. Not model-derived."
        },
        "replay_window": {
          "type": "object",
          "description": "Required iff replay_mode is true. Holds the replay cycle window.",
          "properties": {
            "start": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD). week_ending minus 6 days."
            },
            "end": {
              "type": "string",
              "description": "ISO-8601 date (YYYY-MM-DD). Copied from the override bundle week_ending."
            }
          },
          "required": [
            "start",
            "end"
          ]
        }
      }
    },
    "lead_signal": {
      "type": "object",
      "required": [
        "headline",
        "actor",
        "body",
        "source_url",
        "confidence_preliminary"
      ],
      "properties": {
        "headline": {
          "type": "string"
        },
        "actor": {
          "type": "string",
          "enum": [
            "RU",
            "CN",
            "IR",
