{
  "schema_version": "1.0",
  "description": "Consolidated schema registry for all 7 monitors. Defines every report field, its source (synthesis / persistent-state / publisher / carry-forward), the dashboard section that renders it, and the synthesis-to-report field mapping. The publisher and preflight checks validate against this file.",
  "last_updated": "2026-04-09",
  "field_sources": {
    "synthesis": "Produced by the synthesiser each week",
    "persistent-state": "Read from persistent-state.json (longitudinal memory)",
    "publisher-build": "Computed by publisher.py at publish time",
    "carry-forward": "Carried from previous report if synthesis doesn't provide it",
    "analyst-legacy": "Originally produced by analyst cron; now carry-forward until synthesis covers it"
  },
  "monitors": {
