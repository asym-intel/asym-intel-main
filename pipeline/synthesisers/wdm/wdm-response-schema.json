            "type": "string"
          },
          "changelog": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string"
                },
                "change": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                }
              }
            }
          },
          "ert_classification": {
            "type": [
              "object",
              "null"
            ],
            "description": "V-Dem Episode of Regime Transformation classification. Null when no active episode. Populated from reasoner ert_episode_review[].",
            "properties": {
              "episode_type": {
                "type": "string",
                "enum": [
                  "stand_alone",
                  "bell_turn",
                  "u_turn",
                  "none"
                ],
                "description": "V-Dem episode-type canon \u2014 per synthesiser-domain \u00a7ERT CLASSIFICATION."
              },
              "episode_phase": {
                "type": "string",
                "enum": [
                  "onset",
                  "mid_episode",
                  "reversal",
                  "post_episode"
                ],
                "description": "Phase within the active episode."
              },
              "v_dem_episode_id": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "V-Dem episode identifier when available."
              }
            }
          }
        }
      }
    },
