{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FIM Curator Drift Register (fim-curator-drift-v1.0)",
  "description": "File-output schema for the deterministic Curator stage for the Financial Integrity Monitor (financial-integrity). LLM-free: no curator_model, no advisory_notes, no structured_claims. Output is a drift register emitted every cycle (including null cycles) with four typed triggers (T1-T4) firing at advisory severity only. Non-blocking by design (F5/F6). Generated from pipeline/synthesisers/_shared/curator-drift-schema.template.json by generate_curator_schemas.py \u2014 DO NOT EDIT BY HAND.",
  "type": "object",
  "required": [
    "_meta",
    "triggers_fired",
    "cycle_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": [
        "schema_version",
        "monitor_slug",
        "cycle_id",
        "curator_commit_sha"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "fim-curator-drift-v1.0"
        },
        "monitor_slug": {
          "type": "string"
        },
        "cycle_id": {
          "type": "string"
        },
        "curator_deterministic": {
          "const": true
        },
        "curator_model": {
          "type": "null"
        },
        "curator_commit_sha": {
          "type": "string"
        },
        "computed_at": {
          "type": "string",
          "format": "date-time"
        },
        "methodology_version": {
          "type": "string"
        },
        "input_provenance": {
          "type": "object",
          "description": "Which prior cycles' chains + interpret outputs this computation consumed.",
          "additionalProperties": false,
          "properties": {
            "prior_cycle_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "window_size": {
              "type": "integer",
              "minimum": 1
            },
            "non_null_cycles_in_window": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "force_reissue": {
          "type": "object",
          "description": "Audit block written when curator artefact is force-reissued (governed --force path, AD-2026-04-24l). Optional: only present on forced re-issues.",
          "required": [
            "previous_artefact_sha",
            "previous_artefact_written_at",
            "reason",
            "ad_reference",
            "operator",
            "forced_at"
          ],
          "additionalProperties": false,
          "properties": {
            "previous_artefact_sha": {
              "type": "string",
              "description": "SHA of the artefact being replaced."
            },
            "previous_artefact_written_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the replaced artefact was written."
            },
            "reason": {
              "type": "string",
              "description": "Why force re-issue was authorised."
            },
            "ad_reference": {
              "type": "string",
              "description": "AD authorising the force path (e.g. AD-2026-04-24l)."
            },
            "operator": {
              "type": "string",
              "description": "Operator who authorised the force re-issue."
            },
            "forced_at": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp of the force re-issue dispatch."
            }
          }
        }
      }
    },
    "triggers_fired": {
      "type": "array",
      "description": "One entry per trigger firing this cycle. Empty array if no triggers fired. Curator is non-blocking (F6): a fired trigger is advisory only, never halts the publish chain.",
      "items": {
        "type": "object",
        "required": [
          "trigger",
          "severity",
          "evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "trigger": {
            "enum": [
              "T1",
              "T2",
              "T3",
              "T4"
            ]
          },
          "severity": {
            "enum": [
              "advisory"
            ]
          },
          "evidence": {
            "type": "object",
            "description": "Trigger-specific evidence payload. Shape varies by trigger; see curator_base.py _trigger_T1..T4.",
            "additionalProperties": true
          },
          "flags": {
            "type": "array",
            "description": "Trigger-level flags.",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "cycle_summary": {
      "type": "object",
      "description": "Summary stats Curator computed this cycle, regardless of whether triggers fired. Present even on null cycles so carry-forward and shape continuity are measurable.",
      "required": [
        "structured_claims_count",
        "entity_registry_size",
        "carry_forward_rate"
      ],
      "additionalProperties": false,
      "properties": {
        "structured_claims_count": {
          "type": "integer",
          "minimum": 0
        },
        "entity_registry_size": {
          "type": "integer",
          "minimum": 0
        },
        "carry_forward_rate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "shape_fingerprint": {
          "type": "string"
        },
        "methodology_version": {
          "type": "string"
        },
        "cycle_disposition": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "normal_cycle",
            "material_change",
            "null_cycle",
            null
          ]
        },
        "methodology_drift_status": {
          "type": "object",
          "description": "G11 (AD-2026-04-26-AJ) \u2014 deterministic methodology-vs-persistent-state drift check.",
          "oneOf": [
            {
              "description": "Uninitialised case: persistent-state missing or lacks _meta.required_modules.",
              "required": [
                "uninitialised",
                "drift_present"
              ],
              "additionalProperties": false,
              "properties": {
                "uninitialised": {
                  "const": true
                },
                "drift_present": {
                  "type": "null"
                },
                "reason": {
                  "type": "string"
                }
              }
            },
            {
              "description": "Live case: persistent-state declared _meta.required_modules; full comparison performed.",
              "required": [
                "uninitialised",
                "methodology_version_active",
                "methodology_version_declared_in_state",
                "version_match",
                "required_modules_declared",
                "required_modules_present",
                "missing_modules",
                "drift_present"
              ],
              "additionalProperties": false,
              "properties": {
                "uninitialised": {
                  "const": false
                },
                "methodology_version_active": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "methodology_version_declared_in_state": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "version_match": {
                  "type": "boolean"
                },
                "required_modules_declared": {
                  "type": "integer",
                  "minimum": 0
                },
                "required_modules_present": {
                  "type": "integer",
                  "minimum": 0
                },
                "missing_modules": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "drift_present": {
                  "type": "boolean"
                }
              }
            }
          ]
        }
      }
    },
    "curator_error": {
      "type": "boolean",
      "description": "True if the Curator itself hit an internal error (missing input, validation failure). Strictly orthogonal to triggers_fired."
    },
    "curator_flags": {
      "type": "array",
      "description": "Register-level flags (not trigger-scoped). E.g. 'window_incomplete' when fewer than window_size prior cycles exist.",
      "items": {
        "type": "string"
      }
    },
    "schema_canonicalizations": {
      "type": "array",
      "description": "Telemetry-only list of accepted schema alias canonicalisations observed while validating curator inputs.",
      "items": {
        "type": "string"
      }
    }
  }
}
