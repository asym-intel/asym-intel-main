    "structured_claims": {
      "type": "array",
      "description": "Triple store of every factual assertion in this interpretation. Populated by the Interpreter; consumed by the Composer (for claim_trace[] provenance) and the Reviewer gate (Step 2).",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "entity",
          "predicate",
          "value",
          "evidence_id",
          "confidence",
          "source_module"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^aim-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}$",
            "description": "Stable within a cycle. Format: aim-int-{ISO-date}-{4-digit-sequence}."
          },
          "entity": {
            "type": "string",
            "minLength": 1
          },
          "predicate": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "object"
              },
              {
                "type": "array"
              }
            ],
            "description": "The asserted value. Accept string/number/object/array."
          },
          "evidence_id": {
            "type": "string",
            "minLength": 1,
            "description": "References weekly-research source_id or KB entry_id."
          },
          "confidence": {
            "type": "string",
            "enum": [
              "Confirmed",
              "High",
              "Assessed",
              "Possible"
            ]
          },
          "source_module": {
            "type": "string",
            "description": "Which module or field the claim first appears in."
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "gaps_register": {
      "type": "array",
      "description": "Optional. What evidence would improve Uncertain claims.",
      "items": {
        "type": "object",
        "required": [
          "gap_id",
          "description"
        ],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^aim-int-[0-9]{4}-[0-9]{2}-[0-9]{2}-G[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "affected_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "proposed_patches": {
      "type": "array",
      "description": "Sprint 3 Step 4a.2 (AD-2026-04-23l §4.2) — Appendix A patch emission. OPTIONAL top-level array naming the material-change patches this interpretation proposes to the Applier, per pipeline-doctrine Appendix A. Under null_cycle the prompt contract requires an empty array (never omission). Each patch carries the 5 Appendix A required fields: rule_applied, evidence_ids, confidence, material_change_justification, target_kb_path. The Applier is the authoritative rejector of malformed patches; this schema block performs structural gatekeeping only.",
      "items": {
        "type": "object",
        "required": [
          "rule_applied",
          "evidence_ids",
          "confidence",
          "material_change_justification",
          "target_kb_path"
        ],
        "properties": {
          "rule_applied": {
            "type": "string",
            "minLength": 1,
            "description": "The methodology rule invoked to justify this patch. Free-form string until the enum is formalised (Sprint 4)."
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Array of evidence IDs from the weekly-research bundle or KB that support the patch. Must be non-empty."
          },
          "confidence": {
            "type": "string",
            "enum": [
              "Confirmed",
              "High",
              "Assessed",
              "Possible"
            ]
          },
          "material_change_justification": {
            "type": "string",
            "minLength": 1,
            "description": "One-sentence rationale for why this change is material (not cosmetic rewording of existing KB state)."
          },
          "target_kb_path": {
            "type": "string",
            "minLength": 1,
            "description": "The KB path being updated (e.g. 'module_2.models[Anthropic/Claude Opus 4.6]' or 'module_7.vectors[ai_fimi_layer].rating')."
          },
          "patch_id": {
            "type": "string",
            "description": "Optional stable patch ID. Applier may stamp one if absent."
          },
          "operation": {
            "type": "string",
            "enum": [
              "create",
              "update",
              "archive",
              "carry-forward-verified"
            ],
            "description": "Optional Appendix A operation. Applier defaults to 'update' if absent."
          },
          "prior_value": {
            "description": "Optional prior-value snapshot for optimistic concurrency. Applier rejects if current KB state does not match."
          },
          "new_value": {
            "description": "Optional new value the patch applies."
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
