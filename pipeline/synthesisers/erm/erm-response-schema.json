{
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "research_model": {
          "type": "string"
        },
        "monitor_slug": {
          "type": "string"
        },
        "synthesised_at": {
          "type": "string"
        },
        "week_ending": {
          "type": "string"
        },
        "null_signal_week": {
          "type": "boolean"
        },
        "null_signal_reason": {
          "type": "string"
        }
      }
    },
    "planetary_status_snapshot": {
      "type": "object",
      "properties": {
        "boundaries_exceeded": {
          "type": "integer"
        },
        "boundaries_high_risk": {
          "type": "integer"
        },
        "boundaries_increasing_risk": {
          "type": "integer"
        },
        "boundaries_safe": {
          "type": "integer"
        },
        "status_delta_this_week": {
          "type": "string"
        },
        "lead_signal": {
          "type": "string"
        }
      }
    },
    "planetary_boundary_tracker": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "boundary": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "status_delta": {
            "type": "string"
          },
          "key_indicator": {
            "type": "string"
          },
          "data_source": {
            "type": "string"
          },
          "week_development": {
            "type": [
              "string",
              "null"
            ]
          },
          "filter_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "tipping_point_tracker": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tipping_element": {
            "type": "string",
            "enum": [
              "amoc",
              "amazon_dieback",
              "greenland_ice_sheet",
              "west_antarctic_ice_sheet",
              "permafrost_methane",
              "coral_reef_collapse",
              "context_system"
            ],
            "description": "Six core tipping systems per synthesiser-domain \u00a7SIX CORE TIPPING SYSTEMS. Use 'context_system' for named context systems (east_antarctic_ice_sheet, boreal_forest_shift, sahel_greening_collapse) when triggered \u2014 populate context_system_name alongside."
          },
          "proximity": {
            "type": "string"
          },
          "probability_preliminary": {
            "type": "string"
          },
          "key_indicator": {
            "type": "string"
          },
          "cascade_risk": {
            "type": "string"
          },
          "cascade_chain": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "amoc_fovs_proxy": {
            "type": [
              "string",
              "null"
            ]
          },
          "context_system_name": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "east_antarctic_ice_sheet",
              "boreal_forest_shift",
              "sahel_greening_collapse"
            ],
            "description": "Required when tipping_element == 'context_system'. Null otherwise. Canonical context-system enum per reasoner-schema \u00a7tipping_system_review."
          }
        }
      }
    },
    "extreme_events_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "climate_security_nexus": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "policy_law_compliance": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "icj_tracker": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "last_development": {
          "type": "string"
        },
        "last_development_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_milestone": {
          "type": "string"
        },
        "significance": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        }
      }
    },
    "loss_damage_tracker": {
      "type": "object",
      "properties": {
        "mechanism_status": {
          "type": "string"
        },
        "committed_usd": {
          "type": "integer"
        },
        "disbursed_usd": {
          "type": "integer"
        },
        "disbursement_ratio": {
          "type": "number"
        },
        "compliance_cycle": {
          "type": "string"
        },
        "key_development": {
          "type": "string"
        },
        "filter_tag": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "attribution_gap_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "case": {
            "type": "string"
          },
          "governance_status": {
            "type": "string"
          },
          "this_week_development": {
            "type": [
              "string",
              "null"
            ]
          },
          "filter_tag": {
            "type": "string"
          },
          "key_metric": {
            "type": "string"
          },
          "source": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "reverse_cascade_check": {
      "type": "object",
      "properties": {
        "checked": {
          "type": "boolean"
        },
        "geopolitical_event": {
          "type": [
            "string",
            "null"
          ]
        },
        "accelerates_boundary": {
          "type": "boolean"
        },
        "affected_boundary": {
          "type": [
            "string",
            "null"
          ]
        },
        "cascade_description": {
          "type": [
            "string",
            "null"
          ]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "regional_coverage": {
      "type": "object",
      "properties": {
        "sub_saharan_africa_items": {
          "type": "integer"
        },
        "mena_items": {
          "type": "integer"
        },
        "south_asia_items": {
          "type": "integer"
        },
        "ocean_systems_items": {
          "type": "integer"
        },
        "fm_erm_02_met": {
          "type": "boolean"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "key_judgments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "judgment": {
            "type": "string"
          },
          "confidence_preliminary": {
            "type": "string"
          },
          "boundary_or_element": {
            "type": "string"
          },
          "trajectory": {
            "type": "string"
          }
        }
      }
    },
    "weekly_brief_draft": {
      "type": "string"
    },
    "cross_monitor_candidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "weaponisation_events": {
      "type": "array",
      "description": "Events where a natural asset or environmental condition is weaponised. Sourced from reasoner weaponisation_audit[]. Per synthesiser-domain \u00a7F1/\u00a7F2 filters and four-filter classification.",
      "items": {
        "type": "object",
        "properties": {
          "event_summary": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "natural_asset": {
            "type": "string",
            "description": "Earth-system asset or condition weaponised (e.g. water, food, critical minerals, forest cover)."
          },
          "earth_system_impact": {
            "type": "string",
            "description": "Planetary boundary or tipping system affected."
          },
          "filter_classification": {
            "type": "object",
            "properties": {
              "f1_threat_multiplier": {
                "type": "boolean"
              },
              "f2_regulatory_vacuum": {
                "type": "boolean"
              },
              "f3_tipping_point_precursor": {
                "type": "boolean"
              },
              "f4_attribution_gap": {
                "type": "boolean"
              }
            }
          },
          "confidence": {
            "type": "string",
            "enum": [
              "Confirmed",
              "High",
              "Assessed",
              "Possible"
            ],
            "description": "4-tier canonical confidence ladder per ops/CANONICAL-VOCABULARY.md \u00a7Confidence."
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "event_summary",
          "natural_asset",
          "earth_system_impact",
          "confidence"
        ]
      }
    },
    "aerosol_dual_risk_flag": {
      "type": "array",
      "description": "Atmospheric aerosol dual-risk cases \u2014 where cooling masks warming AND air-quality mortality is elevated. Sourced from reasoner boundary_review items where boundary=='atmospheric_aerosols' and aerosol_dual_risk_triggered is true. Per synthesiser-domain \u00a7DUAL RISK.",
      "items": {
        "type": "object",
        "properties": {
          "region": {
            "type": "string"
          },
          "cooling_masking_estimate_w_m2": {
            "type": [
              "number",
              "null"
            ]
          },
          "pm25_mortality_indicator": {
            "type": [
              "string",
              "null"
            ]
          },
          "dual_risk_summary": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "Confirmed",
              "High",
              "Assessed",
              "Possible"
            ],
            "description": "4-tier canonical confidence ladder per ops/CANONICAL-VOCABULARY.md \u00a7Confidence."
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "region",
          "dual_risk_summary",
          "confidence"
        ]
      }
    }
  },
  "required": [
    "_meta",
    "planetary_status_snapshot",
    "planetary_boundary_tracker",
    "tipping_point_tracker",
    "extreme_events_log",
    "climate_security_nexus",
    "policy_law_compliance",
    "icj_tracker",
    "loss_damage_tracker",
    "attribution_gap_cases",
    "reverse_cascade_check",
    "regional_coverage",
    "key_judgments",
    "weekly_brief_draft",
    "cross_monitor_candidates",
    "weaponisation_events",
    "aerosol_dual_risk_flag"
  ]
}
